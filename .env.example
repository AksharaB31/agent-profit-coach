PROJECT_NAME="Agent Profit Coach API"
VERSION="1.0.0"
ENVIRONMENT="development"
HOST="0.0.0.0"
PORT=8000

DATABASE_URL="mysql+pymysql://root:@localhost:3307/afineagent" 
REDIS_HOST="localhost"
REDIS_PORT=6379

SECRET_KEY="change-this-in-production"
API_KEY="change-this-in-production"

# ML MODELS
PROFIT_MODEL_PATH="app/ml/models/ml_profit_model_oneway_v1.pkl"
ROUNDTRIP_PROFIT_MODEL_PATH="app/ml/models/ml_profit_model_roundtrip_v1.pkl"
CONVERSION_MODEL_PATH="app/ml/models/conversion_model.pkl"

# PROFIT COACH SCORING WEIGHTS
PROFIT_WEIGHT=0.40
RELIABILITY_WEIGHT=0.25
PRICE_WEIGHT=0.15
CONVENIENCE_WEIGHT=0.10
CONVERSION_WEIGHT=0.10

# ENTERPRISE ENGINE CONFIGURATION
MIN_BOOKING_THRESHOLD=5
DEFAULT_RELIABILITY_SCORE=0.80
DEFAULT_BOOKING_SUCCESS_PROBABILITY=0.85
DEFAULT_CANCELLATION_RISK=0.10
DEFAULT_MARKUP_PERCENTAGE=0.08
MINIMUM_PROFIT_MARGIN=2.0
ENGINE_VERSION="enterprise_v2"

LOG_LEVEL="INFO"
